# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Supabase (EU — Frankfurt recommended for KVKK)
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only — NEVER expose to the browser or commit real values to git
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ──────────────────────────────────────────────
# AI Providers (server-only — Faz 5)
# DeepSeek: text chat streaming  |  Gemini: photo/vision analysis
# ──────────────────────────────────────────────
DEEPSEEK_API_KEY=your_deepseek_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# Optional overrides:
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat
# GEMINI_MODEL=gemini-1.5-flash

# ──────────────────────────────────────────────
# AI cost observability (USD per 1M tokens — tune to your contract)
# ──────────────────────────────────────────────
# AI_COST_DEEPSEEK_INPUT_PER_1M=0.14
# AI_COST_DEEPSEEK_OUTPUT_PER_1M=0.28
# AI_COST_GEMINI_INPUT_PER_1M=0.075
# AI_COST_GEMINI_OUTPUT_PER_1M=0.30
# AI_COST_GEMINI_VISION_EST_TOKENS=1200
# AI_COST_DEEPSEEK_CACHE_HIT_PER_1M=0.014
# AI_COST_USER_DAILY_TOKENS_ALERT=80000
# AI_COST_DAILY_ANOMALY_MULTIPLIER=3

# ──────────────────────────────────────────────
# AI token / cost tuning (optional — defaults are cost-optimized)
# ──────────────────────────────────────────────
# AI_CONTEXT_TURNS=8
# AI_MEMORY_CHARS=1200
# AI_HISTORY_USER_CHARS=400
# AI_HISTORY_COACH_CHARS=600
# AI_MAX_CHAT_TOKENS=800
# AI_MAX_CARD_TOKENS=900
# AI_STRUCTURED_CARDS=false
# AI_CHAT_ANALYTICS=false
# AI_VISION_MAX_DIMENSION=1280
# AI_MIN_QUALITY_SCORE=3   # photo quality gate (1-10); lower = accept more photos
# ERROR_SPIKE_THRESHOLD=25

# ──────────────────────────────────────────────
# Sender.net API Key — https://www.sender.net
# ──────────────────────────────────────────────
SENDER_API_KEY=your_sender_api_key_here

# ──────────────────────────────────────────────
# Google reCAPTCHA v2 — https://www.google.com/recaptcha/admin
# ──────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# ──────────────────────────────────────────────
# Upstash Redis (Rate Limiting) — https://upstash.com
# Required for production rate limiting in middleware.ts
# ──────────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here

# ──────────────────────────────────────────────
# Sentry (Error monitoring) — https://sentry.io
# Create project: Settings → Client Keys (DSN)
# Source maps: Settings → Auth Tokens → SENTRY_AUTH_TOKEN
# ──────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.de.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.de.sentry.io/xxx
# SENTRY_ORG=your-org-slug
# SENTRY_PROJECT=kaify
# SENTRY_AUTH_TOKEN=your_sentry_auth_token_here

# ──────────────────────────────────────────────
# Vercel Cron (daily cleanup) — generate a random secret
# Vercel auto-injects this in production cron jobs
# ──────────────────────────────────────────────
# CRON_SECRET=your_random_secret_here

# ──────────────────────────────────────────────
# Logging — structured JSON logger level
# One of: debug | info | warn | error (default: info in prod, debug otherwise)
# ──────────────────────────────────────────────
# LOG_LEVEL=info

# ──────────────────────────────────────────────
# Web Push (VAPID) — phone push notifications (PWA)
# Generate with:  npx web-push generate-vapid-keys
# Public key is exposed to the browser; private key is server-only.
# ──────────────────────────────────────────────
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key_here
# VAPID_PRIVATE_KEY=your_vapid_private_key_here
# VAPID_SUBJECT=mailto:support@kaify.org

# ──────────────────────────────────────────────
# Capacitor native app — WebView loads this URL (remote server mode)
# Dev Android emulator: http://10.0.2.2:3000
# Dev physical device:  http://YOUR_LAN_IP:3000
# Production:           https://your-domain.com
# ───────────────────────────────────────────
# CAPACITOR_SERVER_URL=https://kaify.org

# ──────────────────────────────────────────────
# Firebase Cloud Messaging (Capacitor iOS/Android native push)
# Create a Firebase project → Project settings → Service accounts → Generate key
# Upload APNs key in Firebase Console → Cloud Messaging → Apple app configuration
# ──────────────────────────────────────────────
# Option A — single JSON blob (recommended on Vercel):
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
# Option B — separate fields:
# FIREBASE_PROJECT_ID=your-firebase-project-id
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
