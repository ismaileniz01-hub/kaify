# ──────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Supabase (EU — Frankfurt recommended for KVKK)
# Dashboard: https://supabase.com/dashboard/project/_/settings/api
# ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only — NEVER expose to the browser or commit real values to git
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ──────────────────────────────────────────────
# AI Providers (server-only — Faz 5+)
# ──────────────────────────────────────────────
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────
# Sender.net API Key — https://www.sender.net
# ──────────────────────────────────────────────
SENDER_API_KEY=your_sender_api_key_here

# ──────────────────────────────────────────────
# Google reCAPTCHA v2 — https://www.google.com/recaptcha/admin
# ──────────────────────────────────────────────
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here

# ──────────────────────────────────────────────
# Upstash Redis (Rate Limiting) — https://upstash.com
# Required for production rate limiting in middleware.ts
# ──────────────────────────────────────────────
# UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
