# Kaify — Environment Variables
# Copy to .env.local and fill values. Never commit secrets.

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- Upstash Redis (required in production) ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# --- Cron / ops (required in production) ---
CRON_SECRET=generate_a_long_random_secret

# --- AI providers (required for chat/vision) ---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest

# --- AI cost & limits (optional) ---
AI_COST_DEEPSEEK_INPUT_PER_1M=
AI_COST_DEEPSEEK_OUTPUT_PER_1M=
AI_COST_GEMINI_INPUT_PER_1M=
AI_COST_GEMINI_OUTPUT_PER_1M=
AI_COST_GEMINI_VISION_EST_TOKENS=8000
AI_COST_USER_DAILY_TOKENS_ALERT=500000
AI_COST_DAILY_ANOMALY_MULTIPLIER=2.5
AI_MIN_QUALITY_SCORE=40
AI_VISION_MAX_DIMENSION=2048
ERROR_SPIKE_THRESHOLD=25

# --- Sentry (recommended production) ---
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- CSRF (optional — falls back to service role key if unset) ---
CSRF_SECRET=

# Admin Hub operator password (defaults to isoisking if unset — set in production)
ADMIN_HUB_PASSWORD=

# --- Billing webhook ---
LEMON_SQUEEZY_WEBHOOK_SECRET=

# --- Paddle Billing ---
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
NEXT_PUBLIC_PADDLE_ENV=production
NEXT_PUBLIC_PADDLE_PRICE_ESSENTIAL=pri_01kx5zdq1h5gqx7haw1zx8d1sm
NEXT_PUBLIC_PADDLE_PRICE_ESSENTIAL_YEARLY=pri_01kx5zj0y4st5vhvrz59zm6e13
NEXT_PUBLIC_PADDLE_PRICE_PRO=pri_01kx5zwffccfx1prqtj0b7r3t9
NEXT_PUBLIC_PADDLE_PRICE_PRO_YEARLY=pri_01kx601q2zpzgqnmt36647dkm9
NEXT_PUBLIC_PADDLE_PRICE_PREMIUM=pri_01kx604fmcrrrk0n1wyqgg001g
NEXT_PUBLIC_PADDLE_PRICE_PREMIUM_YEARLY=pri_01kx605e406052t6nbzztgz1dv
PADDLE_PRICE_ESSENTIAL=pri_01kx5zdq1h5gqx7haw1zx8d1sm
PADDLE_PRICE_ESSENTIAL_YEARLY=pri_01kx5zj0y4st5vhvrz59zm6e13
PADDLE_PRICE_PRO=pri_01kx5zwffccfx1prqtj0b7r3t9
PADDLE_PRICE_PRO_YEARLY=pri_01kx601q2zpzgqnmt36647dkm9
PADDLE_PRICE_PREMIUM_MAX=pri_01kx604fmcrrrk0n1wyqgg001g
PADDLE_PRICE_PREMIUM_MAX_YEARLY=pri_01kx605e406052t6nbzztgz1dv
PADDLE_NOTIFICATION_WEBHOOK_SECRET=

# --- Email / waitlist ---
SENDER_API_KEY=

# --- Push notifications ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@kaifyai.org
# Firebase FCM (native push) — JSON service account fields as env vars

# --- reCAPTCHA (optional) ---
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# --- Analytics / legal embeds (optional) ---
NEXT_PUBLIC_TERMLY_ID=
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- App config (optional) ---
ALLOWED_ORIGINS=https://kaifyai.org,https://www.kaifyai.org
LOG_LEVEL=info
DAILY_CHEST_LIMIT_ENABLED=true

# --- Build / deploy (set by Vercel automatically) ---
# VERCEL_ENV=production
# VERCEL_GIT_COMMIT_SHA=
